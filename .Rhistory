kable_styling(
full_width = FALSE,
bootstrap_options = c("striped")
) %>%
row_spec(0, bold = TRUE)
hitters %>%
filter(Pos %in% c("LF", "CF", "RF"))%>%
arrange(-as.numeric(OPS)) %>%
kable() %>%
kable_styling(
full_width = FALSE,

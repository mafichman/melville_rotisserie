library(tidyverse)
library(baseballr)
library(lubridate)
library(kableExtra)
library(purrr)
library(DT)
library(tinytex)
options(tinytex.verbose = TRUE)
# Scrape MLB.com for players
pitchers_all <- mlb_stats(stat_type = 'season', player_pool = "all", stat_group = 'pitching', season = 2025)
hitters_all <- mlb_stats(stat_type = 'season', player_pool = "all", stat_group = 'hitting', season = 2025)
pitchers <- pitchers_all %>%
filter(position_type == "Pitcher",
as.numeric(games_started) > 5) %>%
select(position_abbreviation, player_full_name, team_name, age, strike_outs, era, whip, innings_pitched, games_started) %>%
arrange(as.numeric(whip)) %>%
slice(1:150)  %>%
rename(Pos = position_abbreviation,
Name = player_full_name,
Team = team_name,
Age = age,
K = strike_outs,
ERA = era,
WHIP = whip,
IP = innings_pitched,
Starts = games_started)
hitters <- hitters_all %>%
filter(position_type != "Pitcher",
position_abbreviation != "X",
games_played > 50) %>%
select(position_abbreviation, player_full_name, team_name, age, rbi, ops, avg, home_runs, stolen_bases, games_played) %>%
group_by(position_abbreviation) %>%
arrange(-as.numeric(ops)) %>%
slice(1:30) %>%
rename(Pos = position_abbreviation,
Name = player_full_name,
Team = team_name,
Age = age,
RBI = rbi,
OPS = ops,
AVG = avg,
HR = home_runs,
SB = stolen_bases,
GP = games_played)
hitters %>%
filter(Pos == "C") %>%
kable() %>%
kable_styling(
full_width = FALSE,
bootstrap_options = c("striped")
) %>%
row_spec(0, bold = TRUE)
hitters %>%
filter(Pos == "1B") %>%

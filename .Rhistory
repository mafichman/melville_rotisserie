library(tidyverse)
library(baseballr)
library(lubridate)
library(kableExtra)
library(purrr)
library(DT)
library(tinytex)
options(tinytex.verbose = TRUE)
# Scrape MLB.com for players
pitchers <- mlb_stats(stat_type = 'season', player_pool = "all", stat_group = 'pitching', season = 2025)
hitters <- mlb_stats(stat_type = 'season', player_pool = "all", stat_group = 'hitting', season = 2025)
pitchers <- pitchers %>%
filter(position_type == "Pitcher",
as.numeric(games_started) > 5) %>%
select(position_abbreviation, player_full_name, team_name, age, strike_outs, era, whip, innings_pitched, games_started) %>%
arrange(as.numeric(whip)) %>%
slice(1:200)  %>%
rename(Pos = position_abbreviation,
Name = player_full_name,
Team = team_name,
Age = age,
K = strike_outs,
ERA = era,
WHIP = whip,
IP = innings_pitched,
Starts = games_started)
hitters <- hitters %>%
filter(position_type != "Pitcher",
position_abbreviation != "X",
games_played > 50) %>%
select(position_abbreviation, player_full_name, team_name, age, rbi, ops, avg, home_runs, stolen_bases, games_played) %>%
group_by(position_abbreviation) %>%
arrange(-as.numeric(ops)) %>%
slice(1:50) %>%
rename(Pos = position_abbreviation,
Name = player_full_name,
Team = team_name,
Age = age,
RBI = rbi,
OPS = ops,
AVG = avg,
HR = home_runs,
SB = stolen_bases,
GP = games_played)
hitters %>%
filter(Position == "C") %>%
kable()
glimpse(hitters)
hitters %>%
filter(Pos == "C") %>%
kable()
hitters %>%
filter(Pos == "C") %>%
kable() %>%
kable_styling(full_width = FALSE) %>%
row_spec(0, extra_css = "border-bottom: 1px solid black;") %>%
row_spec(1:nrow(df), extra_css = "border-bottom: 1px solid black;")
hitters %>%
filter(Pos == "C") %>%
kable() %>%
kable_styling(full_width = FALSE) %>%
row_spec(0, extra_css = "border-bottom: 1px solid black;") %>%
row_spec(1:nrow(.), extra_css = "border-bottom: 1px solid black;")
hitters %>%
filter(Pos == "C") %>%
kable() %>%
